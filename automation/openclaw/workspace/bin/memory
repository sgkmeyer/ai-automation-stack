#!/usr/bin/env bash
set -euo pipefail

repo_script="/home/node/repo/scripts/memory-webhook.sh"

if [[ ! -x "${repo_script}" ]]; then
  printf 'memory webhook CLI not found at %s\n' "${repo_script}" >&2
  exit 1
fi

export MEMORY_WEBHOOK_BASE_URL="${MEMORY_WEBHOOK_BASE_URL:-https://n8n.satoic.com/webhook/memory}"

exec "${repo_script}" "$@"
