#!/usr/bin/env bash
set -euo pipefail

if [[ $# -eq 0 ]]; then
  printf 'usage: ./bin/recall-memory QUERY [--limit N]\n' >&2
  exit 1
fi

query=""
limit="5"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --limit)
      limit="${2-}"
      shift 2
      ;;
    *)
      if [[ -n "${query}" ]]; then
        query="${query} $1"
      else
        query="$1"
      fi
      shift
      ;;
  esac
done

exec ./bin/memory recall --query "${query}" --limit "${limit}"
