#!/usr/bin/env bash
set -euo pipefail

repo_script="/home/node/repo/scripts/wiki-api.sh"
log_file="/home/node/.openclaw/workspace/wiki/command-log.ndjson"

if [[ ! -x "${repo_script}" ]]; then
  printf 'wiki api CLI not found at %s\n' "${repo_script}" >&2
  exit 1
fi

export MEMORY_API_BASE_URL="${MEMORY_API_BASE_URL:-http://memory-api:8100}"
export MEMORY_API_TOKEN="${MEMORY_API_TOKEN:-}"
export MEMORY_DEFAULT_ACTOR_TYPE="${MEMORY_DEFAULT_ACTOR_TYPE:-tars}"
export MEMORY_DEFAULT_ACTOR_ID="${MEMORY_DEFAULT_ACTOR_ID:-openclaw}"
export MEMORY_DEFAULT_SOURCE_CLIENT="${MEMORY_DEFAULT_SOURCE_CLIENT:-openclaw}"

mkdir -p "$(dirname "${log_file}")"

command_name="${1:-}"
status="ok"

if output="$("${repo_script}" "$@" 2>&1)"; then
  :
else
  status="error"
fi

COMMAND_NAME="${command_name}" STATUS_VALUE="${status}" python3 - "$@" >>"${log_file}" <<'PY'
import json
import os
import sys
from datetime import datetime, timezone

print(json.dumps({
    "ts": datetime.now(timezone.utc).isoformat(),
    "command": os.environ.get("COMMAND_NAME", ""),
    "args": sys.argv[1:],
    "status": os.environ.get("STATUS_VALUE", "ok"),
}))
PY

printf '%s\n' "${output}"

if [[ "${status}" != "ok" ]]; then
  exit 1
fi
