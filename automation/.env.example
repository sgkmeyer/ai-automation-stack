# .env.example — Required environment variables for the automation stack
# Copy to .env and fill in real values: cp .env.example .env
#
# NEVER commit .env — it is gitignored.

# ---- PostgreSQL ----
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---- n8n ----
N8N_HOST=n8n.satoic.com
N8N_ENCRYPTION_KEY=
ADMIN_EMAIL=

# ---- n8n Task Runner (v2 Code Node execution) ----
N8N_RUNNERS_AUTH_TOKEN=
NODES_EXCLUDE=[]

# ---- Openclaw ----
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOK_TOKEN=

# ---- Chromium / Browserless ----
BROWSERLESS_TOKEN=

# ---- External API keys (used by Openclaw) ----
BRAVE_API_KEY=
N8N_API_KEY=
OPENAI_API_KEY=

# ---- Memory API ----
MEMORY_API_TOKEN=
MEMORY_WEBHOOK_BASE_URL=http://n8n-webhook:5678/webhook/memory
MEMORY_LLM_PROVIDER=anthropic
MEMORY_LLM_API_KEY=
MEMORY_LLM_MODEL=claude-sonnet-4-20250514
MEMORY_DISPLAY_TIMEZONE=America/Toronto
MEMORY_REGISTRY_ARCHIVE_ROOT=/var/lib/registry-archive
MEMORY_REGISTRY_FETCH_TIMEOUT_SECONDS=15
MEMORY_REGISTRY_MAX_EXTRACT_CHARS=20000
