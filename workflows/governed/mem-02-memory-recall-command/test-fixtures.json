{
  "happyPath": {
    "request": {
      "query": "What do I know about Databricks?",
      "synthesize": false,
      "limit": 5
    },
    "expected": {
      "status": "ok",
      "contains": ["entries", "citations", "total_found", "reply_text"]
    }
  },
  "failurePath": {
    "request": {
      "query": "Databricks",
      "entry_type": "bad_type"
    },
    "expected": {
      "statusCode": 422,
      "contains": ["entry_type must be one of"]
    }
  }
}
